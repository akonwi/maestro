use ard/testing

use maestro/api_football

// A trimmed but shape-accurate API-Football /fixtures response:
// one finished match and one not-started match.
let SAMPLE: Str = "\{
  \"response\": [
    \{
      \"fixture\": \{ \"id\": 1001, \"timestamp\": 1700000000, \"status\": \{ \"short\": \"FT\" \} \},
      \"league\": \{ \"id\": 253, \"season\": 2026, \"round\": \"Regular Season - 1\" \},
      \"teams\": \{
        \"home\": \{ \"id\": 1609, \"name\": \"Inter Miami\" \},
        \"away\": \{ \"id\": 1615, \"name\": \"Atlanta United\" \}
      \},
      \"goals\": \{ \"home\": 2, \"away\": 1 \}
    \},
    \{
      \"fixture\": \{ \"id\": 1002, \"timestamp\": 1800000000, \"status\": \{ \"short\": \"NS\" \} \},
      \"league\": \{ \"id\": 253, \"season\": 2026, \"round\": \"Regular Season - 2\" \},
      \"teams\": \{
        \"home\": \{ \"id\": 1613, \"name\": \"LA Galaxy\" \},
        \"away\": \{ \"id\": 1614, \"name\": \"LAFC\" \}
      \},
      \"goals\": \{ \"home\": null, \"away\": null \}
    \}
  ]
\}"

test fn parses_fixtures_response() Void!Str {
  let list = try api_football::parse_fixtures(SAMPLE)
  try testing::assert(list.size() == 2, "expected 2 fixtures, got {list.size()}")

  match list.at(0) {
    f => {
      try testing::assert(f.id == 1001, "first fixture id")
      try testing::assert(f.status == "FT", "first fixture status")
      try testing::assert(f.api_football_league_id == 253, "provider league id")
      try testing::assert(f.season == 2026, "provider season")
      try testing::assert(f.kickoff_at == 1700000000000, "timestamp seconds -> unix ms")
      try testing::assert(f.home_team_name == "Inter Miami", "home team name")
      try testing::assert(f.home_score.expect("home score") == 2, "home score")
      try testing::assert(f.away_score.expect("away score") == 1, "away score")
    },
    _ => try testing::fail("missing first fixture"),
  }

  match list.at(1) {
    f => {
      try testing::assert(f.status == "NS", "second fixture status")
      try testing::assert(f.home_score.is_none(), "unplayed match has no home score")
      try testing::assert(f.away_score.is_none(), "unplayed match has no away score")
    },
    _ => try testing::fail("missing second fixture"),
  }
  try testing::assert(api_football::find_fixture(list, 1002).expect("fixture").id == 1002, "finds requested fixture")
  try testing::assert(api_football::find_fixture(list, 9999).is_none(), "does not trust unrelated response")
  testing::pass()
}

test fn parses_fixture_rounds() Void!Str {
  let list = try api_football::parse_round_fixtures(SAMPLE)
  try testing::assert(list.at(0).expect("fixture").round == "Regular Season - 1", "first round")
  try testing::assert(list.at(1).expect("fixture").round == "Regular Season - 2", "second round")
  testing::pass()
}

test fn rejects_malformed_body() Void!Str {
  match api_football::parse_fixtures("not json") {
    ok(_) => testing::fail("malformed body should not parse"),
    err(_) => testing::pass(),
  }
}

// Lineups with data still being populated: null formation/coach/colors and
// a malformed player entry must not fail the team.
let PARTIAL_LINEUPS: Str = "\{
  \"response\": [
    \{
      \"team\": \{ \"id\": 1609, \"name\": \"Inter Miami\" \},
      \"formation\": null,
      \"coach\": \{\},
      \"startXI\": [
        \{ \"player\": \{ \"id\": 1, \"name\": \"R. Rios\", \"number\": 34, \"pos\": \"G\", \"grid\": \"1:1\" \} \},
        \{ \"player\": \{ \"id\": null, \"name\": \"No Number\", \"number\": null, \"pos\": null, \"grid\": null \} \},
        \{ \"player\": null \}
      ],
      \"substitutes\": []
    \}
  ]
\}"

test fn partial_lineups_decode_leniently() Void!Str {
  let lineups = try api_football::parse_lineups(PARTIAL_LINEUPS)
  try testing::assert(lineups.size() == 1, "one team decoded")
  let team = lineups.at(0).expect("team")
  try testing::assert(team.formation == "", "null formation becomes empty")
  try testing::assert(team.coach == "", "missing coach becomes empty")
  try testing::assert(team.color_primary.is_none(), "missing colors tolerated")
  try testing::assert(team.starters.size() == 2, "malformed player skipped, got {team.starters.size()}")
  Result::ok(())
}

test fn incomplete_outlook_is_treated_as_absent() Void!Str {
  // A response item without prediction percentages should yield none, not an error.
  let body = "\{ \"response\": [ \{ \"predictions\": \{\} \} ] \}"
  let outlook = try api_football::parse_outlook(body)
  try testing::assert(outlook.is_none(), "incomplete outlook should be none")
  Result::ok(())
}

// Upstream lists the same player twice for one fixture (different injury
// types); team news should see each player once.
let DUP_INJURIES: Str = "\{
  \"response\": [
    \{ \"team\": \{ \"id\": 1603 \}, \"player\": \{ \"name\": \"A. Ahmed\", \"type\": \"Missing Fixture\", \"reason\": \"International duty\" \} \},
    \{ \"team\": \{ \"id\": 1603 \}, \"player\": \{ \"name\": \"A. Ahmed\", \"type\": \"Questionable\", \"reason\": \"Injury\" \} \},
    \{ \"team\": \{ \"id\": 1603 \}, \"player\": \{ \"name\": \"B. Smith\", \"type\": \"Missing Fixture\", \"reason\": \"Knee Injury\" \} \}
  ]
\}"

test fn injuries_dedup_per_player() Void!Str {
  let injuries = try api_football::parse_injuries(DUP_INJURIES)
  try testing::assert(injuries.size() == 2, "expected 2 unique players, got {injuries.size()}")
  let first = injuries.at(0).expect("first")
  try testing::assert(first.player == "A. Ahmed", "keeps first record")
  try testing::assert(first.reason == "International duty", "keeps first record's reason")
  Result::ok(())
}

// Standings decode: expanded row fields + conference grouping.
let STANDINGS_BODY: Str = "\{
  \"response\": [
    \{ \"league\": \{ \"standings\": [
      [
        \{ \"rank\": 1, \"team\": \{ \"id\": 1607, \"name\": \"Vancouver Whitecaps\" \}, \"points\": 32, \"goalsDiff\": 22, \"form\": \"WLWDD\", \"description\": \"Promotion - MLS (Play Offs)\", \"group\": \"Western Conference\", \"all\": \{ \"played\": 14, \"win\": 10, \"draw\": 2, \"lose\": 2, \"goals\": \{ \"for\": 34, \"against\": 12 \} \} \}
      ],
      [
        \{ \"rank\": 1, \"team\": \{ \"id\": 1595, \"name\": \"Philadelphia Union\" \}, \"points\": 30, \"goalsDiff\": 14, \"form\": \"WWWDW\", \"description\": \"Promotion - MLS (Play Offs)\", \"group\": \"Eastern Conference\", \"all\": \{ \"played\": 15, \"win\": 9, \"draw\": 3, \"lose\": 3, \"goals\": \{ \"for\": 28, \"against\": 14 \} \} \}
      ]
    ] \} \}
  ]
\}"

test fn parses_expanded_standings() Void!Str {
  let rows = try api_football::parse_standings(STANDINGS_BODY)
  try testing::assert(rows.size() == 2, "two rows across conferences")
  let west = rows.at(0).expect("west")
  try testing::assert(west.team_name == "Vancouver Whitecaps", "team name")
  try testing::assert(west.played == 14 and west.win == 10, "played/win")
  try testing::assert(west.goals_for == 34 and west.goals_against == 12, "goals")
  try testing::assert(west.form == "WLWDD", "form")
  try testing::assert(west.group == "Western Conference", "conference group")
  Result::ok(())
}
