use dram

// Small helpers so every handler writes consistent responses. The error
// envelope is flat: `{ "error": "message" }`.

fn json_response(response: mut dram::Response, status: Int, value: Any) {
  response.json(status, value)
}

fn no_content(response: mut dram::Response) {
  response.status = 204
  response.body = []
}

fn fail(response: mut dram::Response, status: Int, message: Str) {
  let payload: [Str: Str] = ["error": message]
  response.json(status, payload)
}
