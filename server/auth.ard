use go:fmt
use go:github.com/go-chi/chi/v5 as chi
use go:maestro_server/ffi
use go:net/http
use maestro_server/app
use maestro_server/decode
use maestro_server/email
use maestro_server/magic_links
use maestro_server/response
use maestro_server/sessions
use maestro_server/users

// Wire the /auth/* endpoints into the router. No middleware in M2 \u2014
// logout reads its bearer token inline.
fn register(router: mut chi::Mux, a: app::App) {
  router.Post(
    "/auth/request",
    fn(w: http::ResponseWriter, r: mut http::Request) {
      handle_request(a, w, r)
    },
  )
  router.Get(
    "/auth/verify",
    fn(w: http::ResponseWriter, r: mut http::Request) {
      handle_verify_redirect(a, w, r)
    },
  )
  router.Post(
    "/auth/verify",
    fn(w: http::ResponseWriter, r: mut http::Request) {
      handle_verify(a, w, r)
    },
  )
  router.Post(
    "/auth/logout",
    fn(w: http::ResponseWriter, r: mut http::Request) {
      handle_logout(a, w, r)
    },
  )
}

// -----------------------------------------------------------------------
// Handler shells: each one runs a small pure-ish Result-returning
// function and translates the outcome to an HTTP response. Keeps status
// codes in the shell, business logic in the do_* function.
// -----------------------------------------------------------------------

private fn handle_request(a: app::App, w: http::ResponseWriter, r: mut http::Request) {
  match do_request(a, r) {
    ok => response::no_content(w),
    err(message) => response::fail(w, http::StatusBadRequest, message),
  }
}

private fn handle_verify(a: app::App, w: http::ResponseWriter, r: mut http::Request) {
  match do_verify(a, r) {
    ok(payload) => response::json_response(w, http::StatusOK, payload),
    err(message) => response::fail(w, http::StatusBadRequest, message),
  }
}

private fn handle_logout(a: app::App, w: http::ResponseWriter, r: mut http::Request) {
  let token = ffi::BearerToken(r)
  match token.is_empty() {
    true => response::fail(w, http::StatusUnauthorized, "missing or invalid bearer token"),
    false => {
      match sessions::delete(a, token) {
        ok => response::no_content(w),
        err(message) => response::fail(
          w,
          http::StatusInternalServerError,
          "could not delete session: {message}",
        ),
      }
    },
  }
}

// GET /auth/verify?token=X -> 302 to the web app. Never consumes.
private fn handle_verify_redirect(a: app::App, w: http::ResponseWriter, r: mut http::Request) {
  let token = ffi::QueryParam(r, "token")
  match token.is_empty() {
    true => response::fail(w, http::StatusBadRequest, "missing token"),
    false => {
      let target = "{a.config.app_base_url}/auth/verify?token={token}"
      w.Header().Set("Location", target)
      w.WriteHeader(http::StatusFound)
    },
  }
}

// -----------------------------------------------------------------------
// do_* worker functions
// -----------------------------------------------------------------------

// POST /auth/request { email }
// We deliberately never leak whether the email is known.
private fn do_request(a: app::App, r: mut http::Request) Void!Str {
  let addr = try decode_field(r, "email")
  let token = try magic_links::create(a, addr)
  let link = "{a.config.server_base_url}/auth/verify?token={token}"
  let body = "Click the link to sign in to Maestro:\n\n{link}\n\nThe link expires soon and can only be used once."

  // A send failure shouldn't leak upstream \u2014 the user can retry.
  match email::send(a.config, addr, "Your Maestro sign-in link", body) {
    ok => Result::ok(()),
    err(message) => {
      fmt::Println("email send failed for {addr}: {message}")
      Result::ok(())
    },
  }
}

// POST /auth/verify { token } -> { session_token, user }
private fn do_verify(a: app::App, r: mut http::Request) [Str: Any]!Str {
  let token = try decode_field(r, "token")
  let addr = try magic_links::consume(a, token)
  let user = try users::get_or_create_by_email(a, addr)
  let session = try sessions::mint(a, user.id)

  let user_payload: [Str: Any] = [
    "id": user.id,
    "email": user.email,
    "display_name": user.display_name,
  ]
  let payload: [Str: Any] = [
    "session_token": session.token,
    "user": user_payload,
  ]
  Result::ok(payload)
}

// Read a single string field from a JSON request body. All the M2 auth
// bodies are simple `{ "field": "value" }` shapes.
private fn decode_field(r: mut http::Request, name: Str) Str!Str {
  let body = try ffi::ReadBodyString(r)
  match body.is_empty() {
    true => Result::err("empty request body"),
    false => {
      let data = try decode::from_json(body)
      decode::run(data, decode::field(name, decode::string)).map_err(describe_body_error)
    },
  }
}

private fn describe_body_error(e: decode::Error) Str {
  "invalid request: {e.to_str()}"
}
